# Workspace
APP_WORKSPACE=/path/to/INE-Intelligent-Alarm-Repair-Assistant
SCHEDULE_EXPORT_CSV=/path/to/INE-Intelligent-Alarm-Repair-Assistant/dolphinscheduler/schedules_export.csv

# DolphinScheduler
DS_BASE_URL=http://your-ds-host:12345/dolphinscheduler
DS_TOKEN=replace_with_ds_token
DS_PROJECT_CODE=replace_with_main_project_code
DS_FUYAN_PROJECT_CODE=replace_with_fuyan_project_code
DS_FUYAN_PROJECT_NAME=replace_with_fuyan_project_name
DS_ENVIRONMENT_CODE=replace_with_environment_code
DS_TENANT_CODE=replace_with_tenant_code

# Recheck workflows
# Must be valid JSON array. Each item should include:
# project_name, project_code, workflow_name, workflow_code, schedule, level
FUYAN_WORKFLOWS_JSON=[{"project_name":"印尼数仓-质量校验","project_code":"replace_with_fuyan_project_code","workflow_name":"每日复验全级别数据(W-1)","workflow_code":"replace_with_workflow_code","schedule":"每日","level":"all"}]

# Database
DB_HOST=replace_with_db_host
DB_PORT=13306
DB_USER=replace_with_db_user
DB_PASSWORD=replace_with_db_password
DB_NAME=replace_with_db_name

# Alert / result tables
QUALITY_RESULT_TABLE=wattrel_quality_result
QUALITY_ALERT_TABLE=wattrel_quality_alert

# OpenClaw webhook
OPENCLAW_WEBHOOK=http://127.0.0.1:18789/hooks/wattrel/wake
OPENCLAW_HOOK_TOKEN=replace_with_openclaw_hook_token

# TV bot
TV_API_URL=https://tv-service-alert.kuainiu.chat/alert/v2/array
TV_BOT_ID=replace_with_tv_bot_id
TV_APP_ID=alert
TV_MENTIONS=
